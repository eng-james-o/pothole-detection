flowchart TD
    I["Input Image<br/>640×640×3"] --> Stem["Conv Stem<br/>640×640→320×320×32"]
    
    Stem --> L1["C3k2 Block<br/>k=3, depth_multiple=1.0<br/>320×320→160×160×64"]
    
    L1 --> L2["C3k2 Block<br/>160×160→80×80×128"]
    
    L2 --> L3["C3k2 Block + C2ps<br/>Partial Stage Fusion<br/>80×80→40×40×256"]
    
    L3 --> SPPF["SPPF (Spatial Pyramid)<br/>Multi-scale Receptive Field"]
    
    subgraph Backbone["BACKBONE: Ultralytics v11 Optimized"]
        direction TB
        L1
        L2
        L3
        SPPF
    end
    
    SPPF --> P5["P5: 40×40<br/>High-Level Semantics"]
    L3 --> P4["P4: 80×80<br/>Mid-Level Features"]
    L2 --> P3["P3: 160×160<br/>Detail Features"]
    
    subgraph Neck["NECK: Multi-Scale Feature Fusion"]
        direction TB
        P5 --> Up1["Upsample<br/>40×40→80×80"]
        P4 --> Fuse1["C2ps Fusion<br/>Concat + Reduce"]
        Up1 --> Fuse1
        Fuse1 --> Out4["80×80"]
        
        Out4 --> Up2["Upsample<br/>80×80→160×160"]
        P3 --> Fuse2["C2ps Fusion"]
        Up2 --> Fuse2
        Fuse2 --> Out3["160×160"]
        
        Out3 --> Down1["Downsample<br/>160×160→80×80"]
        Down1 --> Fuse3["C2ps Fusion"]
        Out4 --> Fuse3
