    end
    
    Out3 --> FP3["FP3: 160×160"]
    Final4 --> FP4["FP4: 80×80"]
    Final5 --> FP5["FP5: 40×40"]
    
    subgraph Head["DECOUPLED HEAD: Anchor-Free"]
        direction TB
